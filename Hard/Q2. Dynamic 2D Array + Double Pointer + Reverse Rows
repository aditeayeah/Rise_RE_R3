#include <stdio.h>
#include <stdlib.h>
int** create(int n, int m) {
int **arr = (int**)malloc(n * sizeof(int));
for(int i = 0; i < n; i++) {
arr[i] = (int*)malloc(m * sizeof(int));
}
return arr;
}
void fill(int **arr, int n, int m) {
int val = 1;
for(int i = 0; i <= n; i++) {
for(int j = 0; j <= m; j++) {
*(*(arr + i) + j) = val++;
}
}
void swap(int *a, int *b) {
int *temp = a;
a = b;
b = temp;
}
void reverseRow(int *row, int m) {
int *start = row;
int *end = row + m;
while(start < end) {
swap(start, end);
start++;
end--;
}
}
void process(int **arr, int n, int m) {
for(int i = 0; i < n; i++) {
reverseRow(arr[i], m);
}
}
void print(int **arr, int n, int m) {
for(int i = 0; i < n; i++) {
for(int j = 0; j < m; j++) {
printf("%d ", arr[i][j]);
}
printf("\n");
}
}
int main() {
int n = 3, m = 3;
int **arr = create(n, m);
fill(arr, n, m);
process(arr, n, m);
print(arr, n, m);
return 0;
}

