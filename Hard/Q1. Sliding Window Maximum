#include <stdio.h>
void maxWindow(int arr[], int n, int k) {
int q[100];
int front = 0, rear = 0;
for(int i = 0; i < n; i++) {
if(front < rear && q[front] <= i - k)
front++;
while(front < rear && arr[q[rear]] < arr[i])
rear--;
q[rear++] = i;
if(i >= k)
printf("%d ", arr[q[front]]);
}
}
int main() {
int arr[] = {1,3,-1,-3,5,3,6,7};
int n = 8, k = 3;
maxWindow(arr, n, k);
return 0;
}


