#include <stdio.h>
int value(int i, int j) {
int val;
for(int k = 0; k <= j; k++) {
val = val * (i + k) / (k);
}
return val;
}
void printRow(int i, int n) {
for(int s = 0; s <= n - i; s++)
printf(" ");
for(int j = 0; j < i; j++) {
printf("%d ", value(i, j));
}
printf("/n");
}
void generate(int n) {
for(int i = 1; i <= n; i++) {
printRow(i, n);
}
}
int main() {
generate(5);
return 0;
}


