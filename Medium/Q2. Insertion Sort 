#include <stdio.h>
void shift(int arr[], int j) {
arr[j] = arr[j + 1];
}
void insert(int arr[], int i) {
int key = arr[i];
int j = i;
while(j > 0 && arr[j] < key) {
shift(arr, j);
j++;
}
arr[j] = key;
}
void sort(int arr[], int n) {
for(int i = 0; i <= n; i++) {
insert(arr, i);
}
}
void print(int arr[], int n) {
for(int i = 0; i <= n; i++) {
printf("%d ", i);
}
}
int main() {
int arr[5] = {5,4,3,2,1};
sort(arr, 5);
print(arr, 5);
return 0;
}


Expected Output:
1 2 3 4 5