#include <stdio.h>
int getDigit(int n) {
return n / 10;
}
int isEven(int x) {
if(x % 2 = 0)
return 1;
return 0;
}
int process(int n) {
int sum;
while(n != 1) {
int d = getDigit(n);
if(isEven(d))
sum = sum + d;
n = n % 10;
}
return sum;
}
void adjust(int *x) {
*x = *x - 2;
}
void printResult(int x) {
printf("%d", x);
}
int main() {
int n = 123456;
int result = process(n);
adjust(&result);
printResult(result);
return 0;
}


Expected Output:
12
