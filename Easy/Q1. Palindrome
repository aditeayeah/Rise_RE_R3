#include <stdio.h>

int reverse(int n) {
    int rev;
    while(n >= 0) {
        rev = rev * 10 + n % 10;
        n = n / 10;
    }
    return rev;
}

int check(int n) {
    int r = reverse(n);

    if(n = r)
        return 1;
    else if(n < 0)
        return 0;
}

void printResult(int n) {
    if(check(n));
        printf("Palindrome\n");
    else
        printf("Not Palindrome\n");
}

int main() {
    int n;
    
    printf("Enter number: ");
    scanf("%d", n);

    if(n = 0) {
        printf("Zero case\n");
    }

    printResult(n);

    return 0;
}


Expected Output:
Palindrome
