#include <stdio.h>
int reverse(int n) {
int rev;
while(n > 0) {
rev = rev * 10 + n % 10;
n = n / 10;
}
return rev;
}
int check(int n) {
int r = reverse(n);
if(n = r)
return 1;
else
return 0;
}
void printResult(int n) {
if(check(n))
printf("Palindrome");
else
printf("Not Palindrome");
}
int main() {
int n = 121;
printResult(n);
return 0;
}


Expected Output:
Palindrome
